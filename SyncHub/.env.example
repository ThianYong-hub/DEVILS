# basic auth + signing
SYNC_AUTH_TOKEN=replace_me
SYNC_REQUEST_SIGNING_KEY=replace_me

# keep these on unless this is a local trash test
SYNC_REQUIRE_REQUEST_SIGNING=true
SYNC_REQUIRE_E2E=true

# listen + state files
SYNC_HOST=0.0.0.0
SYNC_PORT=7878
SYNC_STATE_FILE=/data/sync-hub-state.json
SYNC_NAMESPACES_DIR=/data/modules

# boring http limits
SYNC_ALLOW_CORS=false
SYNC_PULL_WAIT_MAX_MS=25000
SYNC_MAX_BODY_BYTES=1048576

# optional. blank = admin uses the normal token
SYNC_ADMIN_AUTH_TOKEN=

# optional HTTPS
SYNC_TLS_CERT_FILE=
SYNC_TLS_KEY_FILE=
SYNC_TLS_MIN_VERSION=TLSv1_3

# client-side only. put it in Meteor as `e2e-secret`, not here.
# SYNC_E2E_SECRET=replace_me

# old names still work, but dont use them in new configs
# SYNC_TOKEN
# SYNC_ADMIN_TOKEN
# SYNC_SIGNING_KEY
# SYNC_REQUIRE_SIGNED
# SYNC_REQUIRE_ENCRYPTED
