# Required auth + transport signing
SYNC_AUTH_TOKEN=replace_me
SYNC_REQUEST_SIGNING_KEY=replace_me

# Recommended defaults: keep both on unless you intentionally run a weaker local-only setup
SYNC_REQUIRE_REQUEST_SIGNING=true
SYNC_REQUIRE_E2E=true

# Listener / storage
SYNC_HOST=0.0.0.0
SYNC_PORT=7878
SYNC_STATE_FILE=/data/sync-hub-state.json
SYNC_NAMESPACES_DIR=/data/modules

# Optional HTTP behavior / limits
SYNC_ALLOW_CORS=false
SYNC_PULL_WAIT_MAX_MS=25000
SYNC_MAX_BODY_BYTES=1048576

# Optional admin token. If omitted, admin routes fall back to SYNC_AUTH_TOKEN.
SYNC_ADMIN_AUTH_TOKEN=

# Optional HTTPS
SYNC_TLS_CERT_FILE=
SYNC_TLS_KEY_FILE=
SYNC_TLS_MIN_VERSION=TLSv1_3

# Client-side only: E2E payload secret is not read by the backend.
# Put this into Meteor sync-hub / game-sync-hub as `e2e-secret`, not into the backend env.
# SYNC_E2E_SECRET=replace_me

# Compatibility window only. Prefer the names above.
# Legacy aliases still supported by sync_backend.py:
# SYNC_TOKEN
# SYNC_ADMIN_TOKEN
# SYNC_SIGNING_KEY
# SYNC_REQUIRE_SIGNED
# SYNC_REQUIRE_ENCRYPTED
