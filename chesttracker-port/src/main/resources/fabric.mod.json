{
  "schemaVersion": 1,
  "id": "chesttracker",
  "version": "${version}",
  "name": "Chest Tracker (Unofficial port)",
  "description": "Client side item storage - remember where you've put things. Unofficial port Chest Tracker.",
  "authors": [
    "JackFred",
    "ponuing"
  ],
  "contributors": [
    "WinTone01 - Turkish Translations "
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/chest-tracker-port",
    "sources": "https://github.com/ponuing/ChestTracker",
    "issues": "https://github.com/ponuing/ChestTracker/issues"
  },
  "license": "LGPL-3.0-only",
  "icon": "assets/chesttracker/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "red.jackf.chesttracker.impl.ChestTracker"
    ],
    "chesttracker": [
      "red.jackf.chesttracker.impl.DefaultChestTrackerPlugin"
    ],
    "modmenu": [
      "red.jackf.chesttracker.impl.compat.mods.ChestTrackerModMenu"
    ],
    "whereisit_client": [
      "red.jackf.chesttracker.impl.compat.mods.ChestTrackerWhereIsItPlugin"
    ],
    "shulkerboxtooltip": [
      "red.jackf.chesttracker.impl.compat.mods.shulkerboxtooltip.ChestTrackerShulkerBoxTooltip"
    ],
    "jade": [
      "red.jackf.chesttracker.impl.compat.mods.jade.ChestTrackerJadePlugin"
    ]
  },
  "mixins": [
    {
      "config": "chesttracker.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "chesttracker.accesswidener",
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.issues": "https://github.com/ponuing/ChestTracker/issues",
        "modmenu.github_releases": "https://github.com/ponuing/ChestTracker/releases"
      }
    }
  },
  "depends": {
    "fabricloader": ">=0.17.3",
    "minecraft": ">=1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "yet_another_config_lib_v3": ">=3.8.1"
  },
  "recommends": {
    "searchables": "*"
  },
  "suggests": {
    "modmenu": "*",
    "shulkerboxtooltip": "*",
    "wthit": "*",
    "jade": "*"
  }
}