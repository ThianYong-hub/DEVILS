{
  "schemaVersion": 1,
  "id": "devils-addon",
  "provides": [
    "chesttracker",
    "xaeroplus",
    "xaerominimap",
    "xaeroworldmap",
    "xaerolib",
    "whereisit",
    "searchables",
    "yet_another_config_lib_v3",
    "jackfredlib"
  ],
  "version": "${version}",
  "name": "Devils",
  "description": "Devils Addon for Meteor Client.",
  "icon": "assets/devils-addon/icon.png",
  "authors": [
    "23XT",
    "SOCKETLOST"
  ],
  "license": [
    "GPL-3.0-only",
    "MIT",
    "LGPL-3.0-only",
    "LGPL-3.0-or-later",
    "All Rights Reserved"
  ],
  "contact": {
    "sources": "https://github.com/ThianYong-hub/DEVILS"
  },
  "environment": "client",
  "entrypoints": {
    "preLaunch": [
      "com.example.addon.util.CrashGuard"
    ],
    "meteor": [
      "com.example.addon.AddonTemplate"
    ],
    "main": [
      "red.jackf.jackfredlib.impl.base.ServerTrackerImpl::setup",
      "red.jackf.whereisit.WhereIsIt"
    ],
    "client": [
      "xaero.lib.XaeroLibFabric",
      "xaero.minimap.XaeroMinimapFabric",
      "xaero.map.WorldMapFabric",
      "xaeroplus.fabric.XaeroPlusFabric",
      "red.jackf.chesttracker.impl.ChestTracker",
      "red.jackf.whereisit.client.WhereIsItClient",
      "dev.isxander.yacl3.platform.PlatformEntrypoint"
    ],
    "server": [
      "xaero.lib.XaeroLibFabric",
      "xaero.minimap.XaeroMinimapFabric",
      "xaero.map.WorldMapFabric"
    ],
    "chesttracker": [
      "red.jackf.chesttracker.impl.DefaultChestTrackerPlugin"
    ],
    "whereisit": [
      "red.jackf.whereisit.defaults.WhereIsItDefaultPlugin"
    ],
    "whereisit_client": [
      "red.jackf.chesttracker.impl.compat.mods.ChestTrackerWhereIsItPlugin",
      "red.jackf.whereisit.client.defaults.WhereIsItDefaultClientPlugin"
    ],
    "modmenu": [
      "xaero.lib.mods.XaeroLibModMenu",
      "xaero.common.XaeroHudModMenu",
      "xaero.map.mods.XaeroWorldMapModMenu",
      "xaeroplus.fabric.XaeroPlusModMenu",
      "red.jackf.chesttracker.impl.compat.mods.ChestTrackerModMenu",
      "red.jackf.whereisit.client.compat.WhereIsItModMenu"
    ],
    "shulkerboxtooltip": [
      "red.jackf.chesttracker.impl.compat.mods.shulkerboxtooltip.ChestTrackerShulkerBoxTooltip"
    ],
    "jade": [
      "red.jackf.chesttracker.impl.compat.mods.jade.ChestTrackerJadePlugin"
    ],
    "sodium:config_api_user": [
      "xaeroplus.fabric.XaeroPlusSodiumConfigBuilder"
    ]
  },
  "accessWidener": "META-INF/devils-addon/accesswidener/devils-addon.assimilated.accesswidener",
  "mixins": [
    "META-INF/devils-addon/mixins/addon-template.mixins.json",
    "META-INF/devils-addon/mixins/chesttracker.mixins.json",
    "META-INF/devils-addon/mixins/whereisit.mixins.json",
    "META-INF/devils-addon/mixins/searchables.mixins.json",
    "META-INF/devils-addon/mixins/searchables.fabric.mixins.json",
    "META-INF/devils-addon/mixins/yacl.mixins.json",
    "META-INF/devils-addon/mixins/yacl-fabric.mixins.json",
    "META-INF/devils-addon/mixins/xaerolib.mixins.json",
    "META-INF/devils-addon/mixins/xaerolib.fabric.mixins.json",
    "META-INF/devils-addon/mixins/xaerohud.mixins.json",
    "META-INF/devils-addon/mixins/xaerohud.fabric.mixins.json",
    "META-INF/devils-addon/mixins/xaerominimap.mixins.json",
    "META-INF/devils-addon/mixins/xaerominimap.fabric.mixins.json",
    "META-INF/devils-addon/mixins/xaeroworldmap.mixins.json",
    "META-INF/devils-addon/mixins/xaeroworldmap.fabric.mixins.json",
    "META-INF/devils-addon/mixins/xaeroplus.mixins.json",
    "META-INF/devils-addon/mixins/xaeroplus-fabric.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "minimap_version": "25.3.10",
    "worldmap_version": "1.40.11",
    "xaeroplus_version": "2.30.9"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*",
    "fabricloader": ">=0.18.4",
    "fabric-api": "*"
  }
}
