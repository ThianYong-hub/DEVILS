{
  "schemaVersion": 1,
  "id": "devils-addon",
  "version": "${version}",
  "name": "Devils",
  "description": "Devils Addon for Meteor Client.",
  "icon": "assets/devils-addon/icon.png",
  "authors": [
    "23XT",
    "SOCKETLOST"
  ],
  "contact": {
    "sources": "https://github.com/ThianYong-hub/DEVILS"
  },
  "environment": "client",
  "entrypoints": {
    "preLaunch": [
      "com.example.addon.util.CrashGuard"
    ],
    "meteor": [
      "com.example.addon.AddonTemplate"
    ]
  },
  "accessWidener": "devils-addon.accesswidener",
  "mixins": [
    "addon-template.mixins.json"
  ],
  "jars": [
    {
      "file": "META-INF/jars/${xaero_minimap_jar}"
    },
    {
      "file": "META-INF/jars/${xaero_worldmap_jar}"
    },
    {
      "file": "META-INF/jars/${xaeroplus_jar}"
    },
    {
      "file": "META-INF/jars/chesttracker-port-embedded.jar"
    }
  ],
  "custom": {
    "meteor-client:color": "225,25,25"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
